class Solution {
    private static int upper_bound(List<Integer> list, int key) {
        int low = 0, high = list.size();
        while (low < high) {
            int mid = low + (high - low) / 2;
            if (list.get(mid) <= key)
                low = mid + 1;
            else
                high = mid;
        }
        return (low < list.size()) ? list.get(low) : -1;
    }

    public int minOperations(int[] nums) {
        int max = 100005;
        // 1. Sieve of Eratosthenes to precompute primes up to 100005
        boolean[] isPrime = new boolean[max + 1];
        Arrays.fill(isPrime, true);
        isPrime[0] = isPrime[1] = false;
        for (int p = 2; p * p <= max; p++) {
            if (isPrime[p]) {
                for (int i = p * p; i <= max; i += p)
                    isPrime[i] = false;
            }
        }

        // Convert boolean array to a sorted list of primes for upper_bound
        List<Integer> primeList = new ArrayList<>();
        for (int i = 2; i <= max; i++) {
            if (isPrime[i])
                primeList.add(i);
        }

        int ans = 0;
        for (int i = 0; i < nums.length; i++) {
            if (i % 2 == 1) {
                if (isPrime[nums[i]] == true)
                    if(nums[i]==2)ans+=2;
                    else ans++;
            } else {
                if (isPrime[nums[i]]) {
                    continue;
                } else {
                    int x = upper_bound(primeList, nums[i]);
                    ans += x - nums[i];
                }
            }
        }
        return ans;
    }
}
