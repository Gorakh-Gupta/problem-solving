import java.util.*;

class Solution {
    public List<Integer> survivedRobotsHealths(int[] positions, int[] healths, String directions) {
        int n = positions.length;

        // robot: {position, health, direction, index}
        List<int[]> robots = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            robots.add(new int[]{positions[i], healths[i], directions.charAt(i), i});
        }

        // sort by position
        robots.sort(Comparator.comparingInt(a -> a[0]));

        Stack<int[]> stack = new Stack<>();

        for (int[] robot : robots) {

            if (robot[2] == 'R' || stack.isEmpty() || stack.peek()[2] == 'L') {
                stack.push(robot);
                continue;
            }

            boolean add = true;

            while (!stack.isEmpty() && stack.peek()[2] == 'R' && add) {
                int[] last = stack.peek();

                if (robot[1] > last[1]) {
                    stack.pop();
                    robot[1] -= 1;
                } else if (robot[1] < last[1]) {
                    last[1] -= 1;
                    add = false;
                } else {
                    stack.pop();
                    add = false;
                }
            }

            if (add) {
                stack.push(robot);
            }
        }

        // sort by original index
        List<int[]> survivors = new ArrayList<>(stack);
        survivors.sort((a,b)-> a[3]-b[3]);

        List<Integer> result = new ArrayList<>();
        for (int[] r : survivors) {
            result.add(r[1]);
        }

        return result;
    }
}
