class Solution {
    public int closestTarget(String[] words, String target, int startIndex) {
        int ans = 105;
        int n = words.length;

        if (words[startIndex].equals(target))
            return 0;
        int cnt = 1;
        int i = startIndex + 1;
        i %= n;
        while (i != startIndex) {
            if (words[i].equals(target)) {
                ans = Math.min(ans, cnt);
            }
            cnt++;
            i++;
            i %= n;
        }

        System.out.println(ans);

        i = startIndex - 1 + n;
        i %= n;
        cnt = 1;
        while (i != startIndex) {
            if (words[i].equals(target)) {
                ans = Math.min(ans, cnt);
            }
            cnt++;
            i--;
            i += n;
            i %= n;
        }
        return ans == 105 ? -1 : ans;

    }
}
