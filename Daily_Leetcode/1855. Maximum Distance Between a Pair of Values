class Solution {
public:
    int maxDistance(vector<int>& s1, vector<int>& s2) {
        reverse(s2.begin(), s2.end());

        int ans = 0, i = 0;

        for (auto x : s1) {
            int h = lower_bound(s2.begin(), s2.end(), x) - s2.begin();
            int k = s2.size() - 1 - h;

            ans = max(ans, k - i);
            i++;
        }
        return ans;
    }
};
