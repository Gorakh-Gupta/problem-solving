class Solution {
public:
    int minMirrorPairDistance(vector<int>& nums) {
        map<string, int> mp;
        int ans = INT_MAX;
        for (int i=nums.size()-1;i>=0;i--) {
            string h = to_string(nums[i]);
            int n = h.size();

            if (h[n - 1] == '0') {
                string g = h;
                reverse(g.begin(), g.end());
                int j = 0;
                while (j < n && g[j] == '0') {
                    j++;
                }
                h = h.substr(0, n-j);
            }

            string kk = h;
            reverse(kk.begin(), kk.end());
            if (mp[kk] != 0) {
                ans = min(ans, mp[kk] - i);
            }
            mp[to_string(nums[i])] = i;
        }
        return ans == INT_MAX ? -1 : ans;
    }
};
