class Solution {
    public long minNumberOfSeconds(int mountainHeight, int[] workerTimes) {

        long l = 1, r = 5000050000000000L;
        long ans = -1;
        while (l <= r) {
            long m = l + (r - l) / 2;

            //calculate if mountian can be removed
            long  totalremoved = 0;
            for (int i = 0; i < workerTimes.length; i++) {
                long k = (long) (Math.sqrt(1 + (8 * m / workerTimes[i])) - 1) / 2;
                // System.out.println(k + " "+ m);
                totalremoved += k;
            }
            if (totalremoved >= mountainHeight) {
                ans = m;
                r = m - 1;
            } else
                l = m + 1;

        }
        return ans;

    }
}
