class Solution {
public:
    vector<int> sortByBits(vector<int>& arr) {
        map<int, multiset<int>> mp;

        for (auto x : arr) {
            int k = x;
            int r = 0;
            while (k > 0) {
                r += k % 2;
                k /= 2;
            }
            mp[r].insert(x);
        }
        vector<int> ans;
        for (auto x : mp) {
            auto s = x.second;
            for (auto y : s)
                ans.push_back(y);
        }

        return ans;
    }
};
