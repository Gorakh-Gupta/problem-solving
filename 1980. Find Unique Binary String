class Solution {
    public String findDifferentBinaryString(String[] nums) {
        Set<Integer> s = new HashSet<>();
        int len = nums.length;
        for (int i = 0; i < len; i++) {
            int x = Integer.parseInt(nums[i], 2);
            s.add(x);
        }

        for (int i = 0; i <= len; i++) {
            if (s.contains(i) == false) {
                String ans = Integer.toBinaryString(i);
                String l = "";
                int k = ans.length();
                while (k++ < len)
                    l += "0";
                return l + ans;
            }
        }
        return "0000";
    }
}
