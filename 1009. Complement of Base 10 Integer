class Solution {
    public int bitwiseComplement(int n) {

        List<Integer> a = new ArrayList<>();

        while (n > 0) {
            int r = n % 2;
            a.add(r);
            n /= 2;
        }
        
        if(a.size()==0)a.add(0);

        List<Integer> result = a.stream()
                .map(x -> 1 - x) 
                .collect(Collectors.toList());


        int ans = 0;
        int l = 1;

        for (int i = 0; i < result.size(); i++) {
            // System.out.println(result.get(i));
            ans += result.get(i) * l;
            l *= 2;
        }
        return ans;

    }
}
