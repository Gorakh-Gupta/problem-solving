class Solution {
    public int numSteps(String s) {
        int len  = s.length();
        int carry =0;
        int ans = len -1;
        for(int i=len - 1 ;i >0 ; i--){
            if(s.charAt(i) - '0' + carry ==1){
                carry = 1;
                ans++;
            }
        }
        return ans+carry;
        
    }
}
