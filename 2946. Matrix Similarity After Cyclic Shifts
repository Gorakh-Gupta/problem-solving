class Solution {
    public boolean areSimilar(int[][] mat, int k) {
        int len = mat.length;
        int m = mat[0].length;
        k = k % m;
        
        if (k == 0)
            return true;

        for (int i = 0; i < len; i++) {
            int h = m;
            int v = 0, c = k;
            if (i % 2 == 1)
                c = m - k;
            while (h-- > 0) {
                if (mat[i][v % m] != mat[i][c % m])
                    return false;
                v++;
                c++;
            }
        }
        return true;
    }
}
