class Solution {
    public char findKthBit(int n, int k) {

        StringBuilder s = new StringBuilder("0");
        n--;
        while (n-- > 0) {
            StringBuilder h = new StringBuilder();
            for (int i = 0; i < s.length(); i++) {
                if (s.charAt(i) == '0')
                    h.append(1);
                else
                    h.append(0);
            }

            h.reverse();
            s.append(new StringBuilder("1")).append(h);
        }

        return s.charAt(k - 1);

    }
}
