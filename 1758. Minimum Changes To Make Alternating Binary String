class Solution {
    public int minOperations(String s) {
        int one = 0;
        int zero = 0;

        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            if (i % 2 == 0) {
                if (c == '1')
                    one++;
            } else if (i % 2 == 1 && c == '0')
                one++;
        }

        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            if (i % 2 == 0) {
                if (c == '0')
                    zero++;
            } else if (i % 2 == 1 && c == '1')
                zero++;
        }
        return Math.min(one, zero);

    }
}
